<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home</title>
    <!-- Bootstrap CSS -->
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="container mt-5">
        <div class="alert alert-success" role="alert">
            <h4 class="alert-heading">¡Bienvenido!</h4>
            <p>Has ingresado a la plataforma, {{user.name}}.</p>
            {{#if user.admin}}Soy Admin.{{else}}Soy Usuario.{{/if}}</p>
            <hr>
            <p class="mb-0">¡Explora nuestro catálogo o gestiona tus productos!</p>
        </div>
        <div class="row mt-4">
            <div class="col-md-6">
                <a href="/products" class="btn btn-primary btn-lg btn-block">Ver Productos</a>
            </div>
            <div class="col-md-6">
                <a href="/productsList" class="btn btn-secondary btn-lg btn-block">Ver Lista de Productos</a>
            </div>
            <div class="col-md-6 mt-4">
                <a href="/logout" class="btn btn-danger btn-lg btn-block">Cerrar Sesión</a>
            </div>
        </div>
    </div>
    <!-- Bootstrap JS -->
    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.5.4/dist/umd/popper.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
</body>
</html>
